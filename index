<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>FreshMart — Farm Fresh, Daily Delivered</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet">
<style>
:root{--green:#1a5c2a;--green-mid:#2d7a3a;--green-light:#4caf50;--green-pale:#e8f5e9;--lime:#8bc34a;--lime-pale:#f1f8e9;--orange:#ff6f00;--cream:#fafaf7;--warm:#f5f0e8;--dark:#0f1f12;--text:#1a2e1e;--muted:#5a7060;--border:rgba(26,92,42,0.12);--card-r:18px;--shadow:0 4px 24px rgba(26,92,42,0.10);--shadow-hover:0 12px 40px rgba(26,92,42,0.18)}
*{box-sizing:border-box;margin:0;padding:0;scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--text);overflow-x:hidden}
h1,h2,h3,h4{font-family:'Syne',sans-serif}
nav{position:fixed;top:0;left:0;right:0;z-index:1000;background:rgba(250,250,247,0.93);backdrop-filter:blur(16px);border-bottom:1px solid var(--border);padding:0 2rem;height:64px;display:flex;align-items:center;justify-content:space-between;transition:box-shadow 0.3s}
nav.scrolled{box-shadow:0 2px 20px rgba(0,0,0,0.08)}
.nav-logo{font-family:'Syne',sans-serif;font-size:22px;font-weight:800;color:var(--green);cursor:pointer}
.nav-logo span{color:var(--lime)}
.nav-links{display:flex;gap:2rem}
.nav-links a{font-size:14px;font-weight:500;color:var(--muted);text-decoration:none;transition:color 0.2s;cursor:pointer}
.nav-links a:hover,.nav-links a.active{color:var(--green)}
.nav-right{display:flex;align-items:center;gap:12px}
.cart-btn{position:relative;background:var(--green);color:#fff;border:none;border-radius:40px;padding:9px 20px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;gap:8px}
.cart-btn:hover{background:var(--green-mid);transform:translateY(-1px)}
.cart-count{background:var(--lime);color:var(--green);border-radius:50%;width:20px;height:20px;font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:transform 0.3s cubic-bezier(0.34,1.56,0.64,1)}
.cart-count.pop{animation:popBadge 0.4s cubic-bezier(0.34,1.56,0.64,1)}
@keyframes popBadge{0%{transform:scale(1)}50%{transform:scale(1.6)}100%{transform:scale(1)}}
.page{display:none;padding-top:64px;min-height:100vh}
.page.active{display:block}
.hero{min-height:calc(100vh - 64px);background:linear-gradient(135deg,#0f2d14 0%,#1a5c2a 50%,#0a3d18 100%);position:relative;overflow:hidden;display:flex;align-items:center;padding:4rem 2rem}
.hero-bg-circle{position:absolute;border-radius:50%;background:rgba(255,255,255,0.03)}
.hero-text{position:relative;z-index:2;max-width:560px}
.hero-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(139,195,74,0.2);border:1px solid rgba(139,195,74,0.4);color:var(--lime);border-radius:40px;padding:5px 14px;font-size:12px;font-weight:500;letter-spacing:.05em;margin-bottom:1.5rem;animation:fadeUp 0.6s ease both}
.hero h1{font-size:clamp(2.8rem,5vw,4.5rem);font-weight:800;line-height:1.05;color:#fff;margin-bottom:1.25rem;animation:fadeUp 0.6s 0.1s ease both}
.hero h1 em{font-style:normal;color:var(--lime)}
.hero p{font-size:17px;line-height:1.7;color:rgba(255,255,255,0.7);margin-bottom:2.5rem;max-width:420px;animation:fadeUp 0.6s 0.2s ease both}
.hero-btns{display:flex;gap:12px;animation:fadeUp 0.6s 0.3s ease both}
.btn-primary{background:var(--lime);color:var(--dark);border:none;border-radius:40px;padding:14px 28px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:600;cursor:pointer;transition:all 0.2s}
.btn-primary:hover{background:#9ccc45;transform:translateY(-2px);box-shadow:0 8px 24px rgba(139,195,74,0.4)}
.btn-outline{background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,0.3);border-radius:40px;padding:14px 28px;font-family:'DM Sans',sans-serif;font-size:15px;font-weight:500;cursor:pointer;transition:all 0.2s}
.btn-outline:hover{background:rgba(255,255,255,0.08);border-color:rgba(255,255,255,0.6)}
.hero-fruits{position:absolute;right:0;top:0;bottom:0;width:50%;display:flex;align-items:center;justify-content:center;pointer-events:none}
.fruit-float{position:absolute;animation:floatFruit var(--dur,4s) var(--delay,0s) ease-in-out infinite;filter:drop-shadow(0 8px 24px rgba(0,0,0,0.3))}
@keyframes floatFruit{0%,100%{transform:translateY(0) rotate(var(--rot,0deg))}50%{transform:translateY(-18px) rotate(var(--rot,0deg))}}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.trust-strip{background:var(--warm);border-bottom:1px solid var(--border);padding:1rem 2rem;display:flex;align-items:center;justify-content:center;gap:3rem;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;color:var(--muted)}
.trust-item span:first-child{font-size:20px}
section{padding:4rem 2rem}
.section-label{font-size:12px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--green-mid);margin-bottom:.5rem}
.section-title{font-size:clamp(1.8rem,3vw,2.8rem);font-weight:800;color:var(--dark);margin-bottom:.5rem}
.section-sub{font-size:15px;color:var(--muted);max-width:480px}
.section-head{margin-bottom:2.5rem}
.categories{background:#fff}
.cat-grid{display:flex;gap:12px;flex-wrap:wrap}
.cat-pill{display:flex;align-items:center;gap:8px;background:var(--cream);border:1.5px solid var(--border);border-radius:40px;padding:10px 20px;font-size:14px;font-weight:500;cursor:pointer;transition:all 0.2s;color:var(--muted)}
.cat-pill:hover,.cat-pill.active{background:var(--green);color:#fff;border-color:var(--green);transform:translateY(-2px);box-shadow:0 4px 16px rgba(26,92,42,0.2)}
.cat-pill span:first-child{font-size:18px}
.products-section{background:var(--cream)}
.products-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:20px}
.product-card{background:#fff;border-radius:var(--card-r);border:1px solid var(--border);overflow:hidden;transition:all 0.3s cubic-bezier(0.34,1.2,0.64,1);animation:cardIn 0.4s ease both;cursor:pointer}
.product-card:hover{transform:translateY(-8px) scale(1.01);box-shadow:var(--shadow-hover)}
@keyframes cardIn{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:none}}
.card-img-wrap{height:140px;background:var(--lime-pale);display:flex;align-items:center;justify-content:center;font-size:4rem;transition:transform 0.3s;position:relative;overflow:hidden}
.product-card:hover .card-img-wrap{background:var(--green-pale)}
.product-card:hover .card-emoji{transform:scale(1.15) rotate(-5deg)}
.card-emoji{transition:transform 0.3s;display:block}
.badge-new{position:absolute;top:8px;left:8px;background:var(--orange);color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:20px}
.card-body{padding:1rem}
.card-name{font-family:'Syne',sans-serif;font-size:15px;font-weight:700;margin-bottom:2px}
.card-unit{font-size:12px;color:var(--muted);margin-bottom:10px}
.card-footer{display:flex;align-items:center;justify-content:space-between}
.card-price{font-size:18px;font-weight:700;color:var(--green)}
.card-price-unit{font-size:11px;font-weight:400;color:var(--muted)}
.add-btn{width:36px;height:36px;border-radius:50%;background:var(--green);color:#fff;border:none;font-size:22px;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all 0.2s;flex-shrink:0}
.add-btn:hover{background:var(--lime);transform:scale(1.1) rotate(90deg)}
.add-btn:active{transform:scale(0.9)}
.prices-page{background:var(--cream)}
.prices-header{background:var(--green);color:#fff;padding:3rem 2rem}
.prices-header h1{font-size:2.5rem;font-weight:800;margin-bottom:.5rem}
.prices-header p{opacity:.8;font-size:15px}
.price-filters{display:flex;gap:10px;flex-wrap:wrap;padding:1rem 2rem;background:#fff;border-bottom:1px solid var(--border)}
.filter-chip{padding:7px 16px;border-radius:40px;font-size:13px;font-weight:500;border:1.5px solid var(--border);background:var(--cream);color:var(--muted);cursor:pointer;transition:all 0.2s}
.filter-chip:hover,.filter-chip.active{background:var(--green);color:#fff;border-color:var(--green)}
.prices-table-wrap{padding:1.5rem 2rem;overflow-x:auto}
.prices-table{width:100%;border-collapse:collapse;background:#fff;border-radius:var(--card-r);overflow:hidden;box-shadow:var(--shadow)}
.prices-table th{background:var(--green);color:#fff;padding:12px 16px;text-align:left;font-family:'Syne',sans-serif;font-size:13px;font-weight:600}
.prices-table td{padding:12px 16px;border-bottom:1px solid var(--border);font-size:14px}
.prices-table tr:last-child td{border-bottom:none}
.prices-table tr:hover td{background:var(--lime-pale)}
.trend-up{color:#1b5e20;font-weight:600}.trend-dn{color:#b71c1c;font-weight:600}.trend-same{color:var(--muted)}
.price-bar-wrap{width:80px;background:#f0f0f0;border-radius:4px;height:6px;display:inline-block;vertical-align:middle}
.price-bar{height:100%;border-radius:4px}
.price-summary{display:flex;gap:16px;padding:1rem 2rem;flex-wrap:wrap}
.price-stat{background:#fff;border:1px solid var(--border);border-radius:12px;padding:.75rem 1.25rem;font-size:13px}
.price-stat strong{font-size:20px;font-weight:700;display:block}
.price-stat.up strong{color:#1b5e20}.price-stat.dn strong{color:#b71c1c}.price-stat.same strong{color:var(--muted)}
.cart-page{background:var(--cream);padding-bottom:3rem}
.cart-layout{display:grid;grid-template-columns:1fr 360px;gap:1.5rem;max-width:1100px;margin:0 auto;padding:2rem}
.cart-items-panel{background:#fff;border-radius:var(--card-r);border:1px solid var(--border);overflow:hidden}
.cart-panel-head{padding:1.25rem 1.5rem;border-bottom:1px solid var(--border);font-family:'Syne',sans-serif;font-size:18px;font-weight:700}
.cart-item{display:flex;align-items:center;gap:1rem;padding:1rem 1.5rem;border-bottom:1px solid var(--border);transition:background 0.2s}
.cart-item:last-child{border-bottom:none}
.cart-item:hover{background:var(--cream)}
.cart-item-emoji{font-size:2.5rem;width:56px;height:56px;background:var(--lime-pale);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.cart-item-info{flex:1}
.cart-item-name{font-family:'Syne',sans-serif;font-size:15px;font-weight:700}
.cart-item-unit{font-size:12px;color:var(--muted)}
.qty-ctrl{display:flex;align-items:center;gap:8px}
.qty-btn{width:30px;height:30px;border-radius:50%;border:1.5px solid var(--border);background:#fff;cursor:pointer;font-size:16px;display:flex;align-items:center;justify-content:center;transition:all 0.15s;color:var(--green);font-weight:700}
.qty-btn:hover{background:var(--green);color:#fff;border-color:var(--green)}
.qty-num{font-size:15px;font-weight:600;min-width:20px;text-align:center}
.cart-item-price{font-size:16px;font-weight:700;color:var(--green);min-width:64px;text-align:right}
.cart-remove{background:none;border:none;color:#ccc;font-size:18px;cursor:pointer;padding:4px;transition:color 0.2s}
.cart-remove:hover{color:#e53935}
.cart-empty{text-align:center;padding:4rem 2rem;color:var(--muted)}
.cart-empty-icon{font-size:4rem;margin-bottom:1rem}
.summary-card{background:#fff;border-radius:var(--card-r);border:1px solid var(--border);padding:1.5rem;position:sticky;top:80px}
.summary-title{font-family:'Syne',sans-serif;font-size:18px;font-weight:700;margin-bottom:1.25rem}
.promo-row{display:flex;gap:8px;margin-bottom:1.25rem}
.promo-input{flex:1;padding:9px 12px;border:1.5px solid var(--border);border-radius:10px;font-size:13px;font-family:'DM Sans',sans-serif;outline:none}
.promo-input:focus{border-color:var(--green)}
.promo-btn{padding:9px 14px;background:var(--green-pale);color:var(--green);border:none;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s}
.promo-btn:hover{background:var(--green);color:#fff}
.promo-ok{font-size:12px;color:#2e7d32;margin-top:-10px;margin-bottom:10px;display:none}
.summary-line{display:flex;justify-content:space-between;font-size:14px;padding:6px 0;color:var(--muted)}
.summary-line.total{font-weight:700;font-size:17px;color:var(--text);border-top:1.5px solid var(--border);margin-top:8px;padding-top:12px}
.checkout-btn{width:100%;margin-top:1.25rem;padding:15px;background:var(--green);color:#fff;border:none;border-radius:40px;font-family:'Syne',sans-serif;font-size:15px;font-weight:700;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:8px}
.checkout-btn:hover{background:var(--green-mid);transform:translateY(-2px);box-shadow:0 8px 24px rgba(26,92,42,0.25)}
.wa-order-btn{width:100%;margin-top:10px;padding:12px;background:#25d366;color:#fff;border:none;border-radius:40px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:8px}
.wa-order-btn:hover{background:#128c4e;transform:translateY(-1px)}
.prices-search-wrap{padding:1rem 2rem 0}
.prices-search{width:100%;max-width:360px;padding:10px 14px;border:1.5px solid var(--border);border-radius:40px;font-size:14px;font-family:'DM Sans',sans-serif;outline:none}
.prices-search:focus{border-color:var(--green)}
.wa-float{position:fixed;bottom:24px;right:24px;z-index:900;width:56px;height:56px;border-radius:50%;background:#25d366;color:#fff;border:none;font-size:26px;cursor:pointer;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 20px rgba(37,211,102,0.4);animation:waPulse 3s ease-in-out infinite;transition:transform 0.2s}
.wa-float:hover{transform:scale(1.12);animation-play-state:paused}
@keyframes waPulse{0%,100%{box-shadow:0 4px 20px rgba(37,211,102,0.4)}50%{box-shadow:0 4px 32px rgba(37,211,102,0.7)}}
.toast{position:fixed;bottom:96px;right:24px;z-index:1100;background:var(--dark);color:#fff;padding:12px 20px;border-radius:12px;font-size:14px;font-weight:500;opacity:0;transform:translateY(12px) scale(0.95);transition:all 0.25s;pointer-events:none;max-width:280px}
.toast.show{opacity:1;transform:translateY(0) scale(1)}
.fly-fruit{position:fixed;font-size:28px;pointer-events:none;z-index:2000}
.order-success{text-align:center;padding:4rem 2rem;max-width:480px;margin:0 auto}
.order-success-icon{font-size:5rem;margin-bottom:1rem;animation:successBounce 0.6s ease}
@keyframes successBounce{0%{transform:scale(0)}60%{transform:scale(1.2)}100%{transform:scale(1)}}
.order-success h2{font-size:2rem;font-weight:800;margin-bottom:.75rem;color:var(--green)}
.order-success p{color:var(--muted);font-size:15px;line-height:1.6;margin-bottom:2rem}
.status-steps{text-align:left;background:#fff;border-radius:var(--card-r);border:1px solid var(--border);padding:1.5rem;margin-bottom:1.5rem}
.status-step{display:flex;align-items:flex-start;gap:12px;padding:8px 0}
.step-dot{width:20px;height:20px;border-radius:50%;flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center;font-size:10px}
.step-dot.done{background:var(--green);color:#fff}
.step-dot.active{background:var(--lime);color:#fff;animation:pulse 1.5s infinite}
.step-dot.pending{background:#f0f0f0}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.2)}}
.admin-page{background:#f0f4f0}
.admin-layout{display:flex;min-height:calc(100vh - 64px)}
.admin-sidebar{width:220px;min-width:220px;background:var(--dark);padding:1.5rem 0;display:flex;flex-direction:column;position:sticky;top:64px;height:calc(100vh - 64px);overflow-y:auto}
.admin-logo{padding:0 1.25rem 1.5rem;border-bottom:1px solid rgba(255,255,255,0.1);margin-bottom:1rem}
.admin-logo-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:700;color:var(--lime)}
.admin-logo-sub{font-size:11px;color:rgba(255,255,255,0.4);margin-top:2px}
.admin-nav-item{display:flex;align-items:center;gap:10px;padding:10px 1.25rem;font-size:13.5px;color:rgba(255,255,255,0.55);cursor:pointer;border-left:3px solid transparent;transition:all 0.15s}
.admin-nav-item:hover{background:rgba(255,255,255,0.05);color:rgba(255,255,255,0.85)}
.admin-nav-item.active{background:rgba(139,195,74,0.12);color:var(--lime);border-left-color:var(--lime);font-weight:500}
.admin-main{flex:1;overflow-y:auto}
.admin-topbar{background:#fff;border-bottom:1px solid var(--border);padding:0 1.5rem;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:64px;z-index:10}
.admin-topbar-title{font-family:'Syne',sans-serif;font-size:15px;font-weight:700}
.live-badge{background:#e8f5e9;color:var(--green);font-size:11px;padding:3px 10px;border-radius:20px;font-weight:600}
.admin-content{padding:1.25rem 1.5rem}
.admin-tab{display:none}.admin-tab.active{display:block}
.stats-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px;margin-bottom:1.25rem}
.stat-card{background:#fff;border-radius:14px;padding:1.1rem;border:1px solid var(--border)}
.stat-label{font-size:12px;color:var(--muted);margin-bottom:4px}
.stat-val{font-size:22px;font-weight:700;font-family:'Syne',sans-serif}
.stat-delta{font-size:11px;margin-top:2px}
.stat-up{color:#2e7d32}.stat-dn{color:#c62828}
.a-card{background:#fff;border-radius:14px;border:1px solid var(--border);padding:1rem 1.25rem;margin-bottom:1rem}
.a-card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:.75rem}
.a-card-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700}
.a-two-col{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.a-table{width:100%;border-collapse:collapse;font-size:13px}
.a-table th{text-align:left;padding:9px 12px;font-size:11px;font-weight:600;color:var(--muted);text-transform:uppercase;border-bottom:1px solid var(--border)}
.a-table td{padding:10px 12px;border-bottom:1px solid rgba(0,0,0,0.04);vertical-align:middle}
.a-table tr:last-child td{border-bottom:none}
.a-table tr:hover td{background:var(--cream)}
.a-pill{display:inline-block;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:600}
.pill-green{background:#e8f5e9;color:#2e7d32}.pill-amber{background:#fff8e1;color:#e65100}.pill-blue{background:#e3f2fd;color:#1565c0}.pill-red{background:#ffebee;color:#c62828}
.bar-chart{display:flex;gap:8px;align-items:flex-end;height:80px}
.bar-col{display:flex;flex-direction:column;align-items:center;gap:3px;flex:1}
.bar-body{width:100%;border-radius:4px 4px 0 0;background:var(--lime)}
.bar-lbl{font-size:10px;color:var(--muted);white-space:nowrap}
.admin-input{padding:6px 10px;border:1px solid var(--border);border-radius:8px;font-size:13px;width:70px;text-align:right;font-family:'DM Sans',sans-serif}
.admin-search{padding:8px 14px;border:1px solid var(--border);border-radius:40px;font-size:13px;width:220px;font-family:'DM Sans',sans-serif;outline:none}
.admin-search:focus{border-color:var(--green)}
.admin-select{padding:7px 10px;border:1px solid var(--border);border-radius:8px;font-size:13px;font-family:'DM Sans',sans-serif}
.stock-bar-wrap{width:70px;background:#f0f0f0;border-radius:4px;height:6px;display:inline-block;vertical-align:middle}
.stock-bar{height:100%;border-radius:4px}
.notif-dot{width:7px;height:7px;border-radius:50%;background:#ef5350;display:inline-block;margin-left:4px;vertical-align:middle}
.avatar{width:28px;height:28px;border-radius:50%;background:var(--green-pale);display:inline-flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:var(--green);vertical-align:middle;margin-right:6px}
.small-btn{padding:5px 12px;border:1px solid var(--border);border-radius:8px;font-size:12px;font-family:'DM Sans',sans-serif;cursor:pointer;background:#fff;transition:all 0.15s}
.small-btn:hover{background:var(--green);color:#fff;border-color:var(--green)}
.small-btn-primary{background:var(--green);color:#fff;border-color:var(--green)}
.small-btn-primary:hover{opacity:.88}
@media(max-width:640px){.nav-links{display:none}.hero h1{font-size:2.2rem}.hero-fruits{display:none}.stats-grid{grid-template-columns:1fr 1fr}.cart-layout{grid-template-columns:1fr}.admin-sidebar{display:none}.a-two-col{grid-template-columns:1fr}}
</style>
</head>
<body>
