<script>
const FRUITS=[
  {name:'Mango',emoji:'🥭',price:200,prev:180,unit:'per kg',cat:'Tropical',stock:45,isNew:true},
  {name:'Apple',emoji:'🍎',price:130,prev:140,unit:'per kg',cat:'Imported',stock:32,isNew:false},
  {name:'Banana',emoji:'🍌',price:45,prev:40,unit:'per dozen',cat:'Local',stock:80,isNew:false},
  {name:'Watermelon',emoji:'🍉',price:28,prev:30,unit:'per kg',cat:'Seasonal',stock:12,isNew:false},
  {name:'Grapes',emoji:'🍇',price:95,prev:90,unit:'per kg',cat:'Seasonal',stock:22,isNew:true},
  {name:'Papaya',emoji:'🪴',price:60,prev:55,unit:'per kg',cat:'Tropical',stock:18,isNew:false},
  {name:'Orange',emoji:'🍊',price:70,prev:70,unit:'per kg',cat:'Citrus',stock:60,isNew:false},
  {name:'Guava',emoji:'🍐',price:55,prev:50,unit:'per kg',cat:'Local',stock:5,isNew:false},
  {name:'Pomegranate',emoji:'🫐',price:160,prev:150,unit:'per kg',cat:'Premium',stock:14,isNew:false},
  {name:'Chiku',emoji:'🟤',price:75,prev:80,unit:'per kg',cat:'Local',stock:3,isNew:false},
  {name:'Litchi',emoji:'🍒',price:140,prev:120,unit:'per kg',cat:'Seasonal',stock:20,isNew:true},
  {name:'Pear',emoji:'🍐',price:88,prev:90,unit:'per kg',cat:'Imported',stock:28,isNew:false},
  {name:'Coconut',emoji:'🥥',price:40,prev:38,unit:'each',cat:'Tropical',stock:35,isNew:false},
  {name:'Kiwi',emoji:'🥝',price:180,prev:175,unit:'per kg',cat:'Premium',stock:10,isNew:true},
  {name:'Pineapple',emoji:'🍍',price:65,prev:60,unit:'each',cat:'Tropical',stock:16,isNew:false},
  {name:'Strawberry',emoji:'🍓',price:220,prev:250,unit:'per box',cat:'Premium',stock:8,isNew:true},
];
const ADMIN_ORDERS=[
  {id:'#1042',name:'Ramesh K.',initials:'RK',items:'Mango, Banana, Papaya',amount:'₹340',payment:'COD',status:'packing',time:'2m'},
  {id:'#1041',name:'Sunita P.',initials:'SP',items:'Apple, Grapes',amount:'₹290',payment:'UPI',status:'delivery',time:'18m'},
  {id:'#1040',name:'Ankit J.',initials:'AJ',items:'Watermelon',amount:'₹180',payment:'COD',status:'delivered',time:'42m'},
  {id:'#1039',name:'Meena D.',initials:'MD',items:'Litchi, Chiku, Pear',amount:'₹420',payment:'UPI',status:'delivered',time:'1h'},
  {id:'#1038',name:'Priya S.',initials:'PS',items:'Orange, Banana',amount:'₹195',payment:'WA',status:'delivered',time:'2h'},
  {id:'#1037',name:'Kiran B.',initials:'KB',items:'Pomegranate',amount:'₹320',payment:'COD',status:'new',time:'3m'},
];
let cart={},cartCount=0,currentHomeCat='All',currentProdCat='All',currentPriceFilter='all',promoApplied=false;
function showPage(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a=>a.classList.remove('active'));
  const n=document.getElementById('nav-'+id);if(n)n.classList.add('active');
  window.scrollTo(0,0);
  if(id==='cart')renderCart();
}
function goHome(){showPage('home')}
let toastTimer;
function toast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>el.classList.remove('show'),2800)}
function addToCart(idx,event){
  const f=FRUITS[idx];
  if(!cart[idx])cart[idx]={fruit:f,qty:0};
  cart[idx].qty++;cartCount++;
  updateCartBadge();
  toast('🛒 '+f.emoji+' '+f.name+' added!');
  if(event)flyFruit(f.emoji,event);
}
function updateCartBadge(){const el=document.getElementById('cart-count');el.textContent=cartCount;el.classList.remove('pop');void el.offsetWidth;el.classList.add('pop')}
function flyFruit(emoji,event){
  const el=document.createElement('div');
  el.style.cssText='position:fixed;font-size:28px;pointer-events:none;z-index:2000;left:'+(event.clientX-14)+'px;top:'+(event.clientY-14)+'px;transition:all .6s cubic-bezier(.4,0,.2,1)';
  el.textContent=emoji;document.body.appendChild(el);
  setTimeout(()=>{const r=document.querySelector('.cart-btn').getBoundingClientRect();el.style.left=(r.left+r.width/2-14)+'px';el.style.top=(r.top+r.height/2-14)+'px';el.style.transform='scale(0.2)';el.style.opacity='0'},30);
  setTimeout(()=>el.remove(),700);
}
function filterCat(cat,el){currentHomeCat=cat;document.querySelectorAll('#page-home .cat-pill').forEach(p=>p.classList.remove('active'));el.classList.add('active');renderHomeGrid()}
function renderHomeGrid(){
  const list=FRUITS.filter(f=>currentHomeCat==='All'||f.cat===currentHomeCat).slice(0,8);
  document.getElementById('home-grid').innerHTML=list.map((f,i)=>cardHTML(f,FRUITS.indexOf(f),i*50)).join('');
}
function filterProdCat(cat,el){currentProdCat=cat;document.querySelectorAll('#prod-cats .cat-pill').forEach(p=>p.classList.remove('active'));el.classList.add('active');renderProductsPage()}
function renderProductsPage(){
  const q=(document.getElementById('prod-search')||{}).value||'';
  const list=FRUITS.filter(f=>(currentProdCat==='All'||f.cat===currentProdCat)&&f.name.toLowerCase().includes(q.toLowerCase()));
  document.getElementById('products-grid').innerHTML=list.map((f,i)=>cardHTML(f,FRUITS.indexOf(f),i*40)).join('');
}
function cardHTML(f,idx,delay){
  return `<div class="product-card" style="animation-delay:${delay}ms">
    <div class="card-img-wrap">${f.isNew?'<div class="badge-new">NEW</div>':''}<span class="card-emoji">${f.emoji}</span></div>
    <div class="card-body">
      <div class="card-name">${f.name}</div>
      <div class="card-unit">${f.unit}</div>
      <div class="card-footer">
        <div class="card-price">₹${f.price}<span class="card-price-unit"> /kg</span></div>
        <button class="add-btn" onclick="addToCart(${idx},event)">+</button>
      </div>
    </div>
  </div>`;
}
function filterPrice(type,el){currentPriceFilter=type;document.querySelectorAll('#price-filters .filter-chip').forEach(c=>c.classList.remove('active'));el.classList.add('active');renderPricesTable()}
function renderPricesTable(){
  const q=document.getElementById('price-search').value.toLowerCase();
  let list=FRUITS.filter(f=>f.name.toLowerCase().includes(q));
  if(currentPriceFilter==='up')list=list.filter(f=>f.price>f.prev);
  else if(currentPriceFilter==='down')list=list.filter(f=>f.price<f.prev);
  else if(['Tropical','Citrus','Local','Seasonal','Imported','Premium'].includes(currentPriceFilter))list=list.filter(f=>f.cat===currentPriceFilter);
  document.getElementById('prices-tbody').innerHTML=list.map(f=>{
    const diff=f.price-f.prev,pct=((diff/f.prev)*100).toFixed(1);
    const cls=diff>0?'trend-up':diff<0?'trend-dn':'trend-same';
    const arr=diff>0?'↑':diff<0?'↓':'→';
    const bp=Math.round((f.price/300)*100);
    const bc=diff>0?'#2e7d32':diff<0?'#c62828':'#888';
    return `<tr><td>${f.emoji} <strong>${f.name}</strong><br><span style="font-size:11px;color:var(--muted)">${f.cat}</span></td><td style="color:var(--muted)">₹${f.prev}</td><td style="font-weight:700">₹${f.price}</td><td class="${cls}">${arr} ₹${Math.abs(diff)} (${Math.abs(pct)}%)</td><td><div class="price-bar-wrap"><div class="price-bar" style="width:${bp}%;background:${bc}"></div></div></td><td><button class="small-btn" onclick="addToCart(${FRUITS.indexOf(f)},event)">+ Cart</button></td></tr>`;
  }).join('');
  const up=FRUITS.filter(f=>f.price>f.prev).length,dn=FRUITS.filter(f=>f.price<f.prev).length,sm=FRUITS.length-up-dn;
  document.getElementById('price-summary').innerHTML=`<div class="price-stat up"><strong>${up}</strong>Rising today</div><div class="price-stat dn"><strong>${dn}</strong>Falling today</div><div class="price-stat same"><strong>${sm}</strong>Unchanged</div>`;
}
function renderCart(){
  const keys=Object.keys(cart).filter(k=>cart[k].qty>0);
  const list=document.getElementById('cart-items-list');
  document.getElementById('order-success').style.display='none';
  document.getElementById('cart-layout').style.display='';
  if(!keys.length){
    list.innerHTML='<div class="cart-empty"><div class="cart-empty-icon">🛒</div><div style="font-size:18px;font-weight:600;margin-bottom:.5rem">Your cart is empty</div><div style="color:var(--muted);margin-bottom:1.5rem">Add some fresh fruits!</div><button class="btn-primary" onclick="showPage(\'products\')">Shop Now</button></div>';
    updateSummary(0);document.getElementById('cart-item-count').textContent='';return;
  }
  const total=keys.reduce((s,k)=>s+cart[k].fruit.price*cart[k].qty,0);
  document.getElementById('cart-item-count').textContent='('+keys.length+' item'+(keys.length>1?'s':'')+')';
  list.innerHTML=keys.map(k=>{const{fruit,qty}=cart[k];return`<div class="cart-item"><div class="cart-item-emoji">${fruit.emoji}</div><div class="cart-item-info"><div class="cart-item-name">${fruit.name}</div><div class="cart-item-unit">${fruit.unit} · ₹${fruit.price} each</div></div><div class="qty-ctrl"><button class="qty-btn" onclick="changeQty(${k},-1)">−</button><span class="qty-num">${qty}</span><button class="qty-btn" onclick="changeQty(${k},1)">+</button></div><div class="cart-item-price">₹${fruit.price*qty}</div><button class="cart-remove" onclick="removeItem(${k})">✕</button></div>`;}).join('');
  updateSummary(total);
}
function changeQty(k,d){cart[k].qty=Math.max(0,cart[k].qty+d);if(d>0)cartCount++;else if(d<0)cartCount=Math.max(0,cartCount-1);updateCartBadge();renderCart()}
function removeItem(k){cartCount=Math.max(0,cartCount-cart[k].qty);delete cart[k];updateCartBadge();renderCart()}
function updateSummary(sub){
  const del=sub>0?40:0,disc=promoApplied?Math.round(sub*0.2):0;
  document.getElementById('s-subtotal').textContent='₹'+sub;
  document.getElementById('s-delivery').textContent=del?'₹'+del:'Free';
  document.getElementById('s-discount').textContent='-₹'+disc;
  document.getElementById('s-promo-row').style.display=disc?'flex':'none';
  document.getElementById('s-total').textContent='₹'+(sub+del-disc);
}
function applyPromo(){
  const code=document.getElementById('promo-input').value.trim().toUpperCase();
  if(code==='FRESH20'||code==='MANGO10'){
    promoApplied=true;
    const ok=document.getElementById('promo-ok');ok.style.display='block';ok.textContent=code==='FRESH20'?'✅ 20% off applied!':'✅ 10% off applied!';
    toast('🎉 Promo code applied!');renderCart();
  }else toast('❌ Invalid code. Try FRESH20');
}
function placeOrder(){
  if(!Object.keys(cart).filter(k=>cart[k].qty>0).length){toast('Add items first!');return;}
  cart={};cartCount=0;promoApplied=false;updateCartBadge();
  document.getElementById('cart-layout').style.display='none';
  document.getElementById('order-success').style.display='block';
  toast('🎉 Order placed!');
}
function sendWhatsApp(){
  const keys=Object.keys(cart).filter(k=>cart[k].qty>0);
  let msg='🌿 *FreshMart Order*\n\n';
  if(keys.length){keys.forEach(k=>{const{fruit,qty}=cart[k];msg+=fruit.emoji+' '+fruit.name+' x'+qty+' = ₹'+(fruit.price*qty)+'\n';});const t=keys.reduce((s,k)=>s+cart[k].fruit.price*cart[k].qty,0);msg+='\n💰 *Total: ₹'+(t+40)+'* (incl. ₹40 delivery)\n📍 Delivering to my address\n\nPlease confirm! 🙏';}
  else msg='🌿 Hi FreshMart! I want to place an order. Please share today\'s fruit list 🍎';
  window.open('https://wa.me/919768900183?text='+encodeURIComponent(msg),'_blank');
}
function adminTab(id,el){
  document.querySelectorAll('.admin-tab').forEach(t=>t.classList.remove('active'));
  document.querySelectorAll('.admin-nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('admin-'+id).classList.add('active');el.classList.add('active');
  const titles={dash:'Dashboard',orders:'Orders',pricedit:'Price Editor',stock:'Stock Manager',customers:'Customers'};
  document.getElementById('admin-title').textContent=titles[id];
}
function renderAdminOrders(q='',status=''){
  const list=ADMIN_ORDERS.filter(o=>{const qs=q.toLowerCase();return(o.name.toLowerCase().includes(qs)||o.id.includes(qs))&&(!status||o.status===status)});
  const sp=s=>({new:'<span class="a-pill pill-amber">New</span>',packing:'<span class="a-pill pill-amber">Packing</span>',delivery:'<span class="a-pill pill-blue">Out for Delivery</span>',delivered:'<span class="a-pill pill-green">Delivered</span>'}[s]||s);
  document.getElementById('admin-orders-body').innerHTML=list.map(o=>`<tr><td>${o.id}</td><td><span class="avatar">${o.initials}</span>${o.name}</td><td style="max-width:120px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">${o.items}</td><td>${o.amount}</td><td><span class="a-pill pill-blue">${o.payment}</span></td><td>${sp(o.status)}</td><td><button class="small-btn" onclick="toast('WhatsApp opened!')">WA</button></td></tr>`).join('');
}
function renderAdminPrices(q=''){
  document.getElementById('admin-price-body').innerHTML=FRUITS.filter(f=>f.name.toLowerCase().includes(q.toLowerCase())).map(f=>{
    const diff=f.price-f.prev,pct=((diff/f.prev)*100).toFixed(1);
    const cls=diff>0?'trend-up':diff<0?'trend-dn':'';
    return`<tr><td>${f.emoji} ${f.name}</td><td style="color:var(--muted)">₹${f.prev}</td><td><input class="admin-input" type="number" value="${f.price}" onchange="toast('Price updated!')"></td><td class="${cls}">${diff>0?'↑':diff<0?'↓':'→'} ₹${Math.abs(diff)} (${Math.abs(pct)}%)</td><td><div style="display:inline-flex;align-items:flex-end;gap:1px;height:20px">${[.4,.5,.55,.65,.7,.8,f.price/300].map(h=>`<div style="width:4px;height:${Math.round(h*20)}px;border-radius:1px;background:var(--lime)"></div>`).join('')}</div></td><td><select class="admin-select" style="padding:4px 8px;font-size:12px" onchange="toast('Updated!')"><option>Visible</option><option>Hidden</option></select></td></tr>`;
  }).join('');
}
function renderAdminStock(q='',level=''){
  document.getElementById('admin-stock-body').innerHTML=FRUITS.filter(f=>{
    if(!f.name.toLowerCase().includes(q.toLowerCase()))return false;
    if(!level)return true;
    return(f.stock<10?'low':f.stock<30?'ok':'full')===level;
  }).map(f=>{
    const pct=Math.min(100,Math.round((f.stock/80)*100));
    const lv=f.stock<10?'low':f.stock<30?'ok':'full';
    const pill={low:'pill-red',ok:'pill-amber',full:'pill-green'}[lv];
    const bc={low:'#c62828',ok:'#e65100',full:'#2e7d32'}[lv];
    return`<tr><td>${f.emoji} ${f.name}</td><td style="color:var(--muted)">${f.cat}</td><td><input class="admin-input" type="number" value="${f.stock}" onchange="toast('Stock updated!')"> kg</td><td><div style="display:flex;align-items:center;gap:6px"><div class="stock-bar-wrap"><div class="stock-bar" style="width:${pct}%;background:${bc}"></div></div><span class="a-pill ${pill}">${{low:'Low',ok:'OK',full:'Full'}[lv]}</span></div></td><td style="color:var(--muted);font-size:12px">Today 9AM</td><td><button class="small-btn" onclick="toast('Restock WA sent!')">Restock</button></td></tr>`;
  }).join('');
}
function renderDashCharts(){
  const days=['Mon','Tue','Wed','Thu','Fri','Sat','Sun'],vals=[8400,9100,7600,10200,11300,13800,12480],mx=Math.max(...vals);
  document.getElementById('a-bar-chart').innerHTML=days.map((d,i)=>`<div class="bar-col"><div class="bar-body" style="height:${Math.round((vals[i]/mx)*72)}px"></div><div class="bar-lbl">${d}</div></div>`).join('');
  const top=[...FRUITS].sort((a,b)=>b.stock-a.stock).slice(0,5);
  document.getElementById('a-top-sellers').innerHTML=top.map(f=>`<div style="display:flex;align-items:center;gap:8px;margin-bottom:8px;font-size:13px"><span>${f.emoji}</span><span style="flex:1">${f.name}</span><div style="width:60px;background:#f0f0f0;border-radius:4px;height:6px;overflow:hidden"><div style="width:${Math.round((f.stock/80)*100)}%;height:100%;background:var(--lime);border-radius:4px"></div></div><span style="color:var(--muted)">${f.stock}kg</span></div>`).join('');
}
window.addEventListener('scroll',()=>document.getElementById('navbar').classList.toggle('scrolled',window.scrollY>10));
renderHomeGrid();renderProductsPage();renderPricesTable();renderAdminOrders();renderAdminPrices();renderAdminStock();renderDashCharts();
</script>
</body>
</html>
